@page "/catalogo"
@using Proyecto_Final.Models
<link href="Catalogo.css" rel="stylesheet" />

@inject HttpClient Http

<h3>Catálogo de Productos</h3>
<div class="mb-3">

    <button class="btn btn-primary me-2"
            @onclick="CargarTodos">
        Todos
    </button>

    <button class="btn btn-success"
            @onclick="CargarSinReceta">
        Sin receta
    </button>

</div>

@if (!string.IsNullOrEmpty(mensaje))
{
    <div class="alert alert-warning">
        @mensaje
    </div>
}

@if (productos == null)
{
    <p>Cargando productos...</p>
}
else
{
    <table class="table">

        <thead>

            <tr>
                <th>Nombre</th>
                <th>Laboratorio</th>
                <th>Presentación</th>
                <th>Precio</th>
                <th>Especialidad</th>
            </tr>

        </thead>

        <tbody>

            @foreach (var producto in productos)
            {
                <tr>

                    <td>@producto.Nombre</td>
                    <td>@producto.Laboratorio</td>
                    <td>@producto.Presentacion</td>
                    <td>$@producto.Precio</td>
                    <td>@producto.Especialidad</td>

                </tr>
            }

        </tbody>

    </table>
}
<div class="mt-3">

    <a href="/" class="btn btn-primary">
        Volver al Inicio
    </a>
</div>

@code {

    List<ProductoApi>? productos;

    string mensaje = "";

    protected override async Task OnInitializedAsync()
    {
        try
        {
            productos = await Http.GetFromJsonAsync<List<ProductoApi>>(
                "https://api-udec-pweb-aedec9hxbugye0am.westus3-01.azurewebsites.net/api/salud/productos"
            );
        }
        catch (Exception)
        {
            mensaje = "No fue posible conectar con la API en este momento.";

        }
    }
    async Task CargarTodos()
    {
        try
        {
            mensaje = "";

            productos = await Http.GetFromJsonAsync<List<ProductoApi>>(
                "https://api-udec-pweb-aedec9hxbugye0am.westus3-01.azurewebsites.net/api/salud/productos"
            );
        }
        catch (Exception)
        {
            mensaje = "No fue posible conectar con la API en este momento.";

        }
    }

    async Task CargarSinReceta()
    {
        try
        {
            mensaje = "";

            productos = await Http.GetFromJsonAsync<List<ProductoApi>>(
                "https://api-udec-pweb-aedec9hxbugye0am.westus3-01.azurewebsites.net/api/salud/productos/sinreceta"
            );
        }
        catch (Exception)
        {
            mensaje = "No fue posible conectar con la API en este momento.";

        }
    }
}